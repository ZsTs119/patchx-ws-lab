        { "action": "expect_no_ws", "type": "goodbye", "timeout_ms": 1000 }
      ]
    },
    {
      "id": "module.audio-pcm-48000-60ms",
      "label": "PCM 48000Hz 60ms",
      "auto_connect": false,
      "steps": [
        { "action": "set_audio_profile", "profile": { "format": "pcm", "sample_rate": 48000, "frame_duration": 60 } },
        { "action": "connect_hello", "timeout_ms": 12000 },
